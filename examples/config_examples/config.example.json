{
  "_comment": "POE2 Master Overlay - Example Configuration File",
  "_note": "Copy this file to ~/.config/poe2-master/config.json to customize settings",
  
  "window": {
    "_description": "Overlay window settings",
    "width": 400,
    "height": 300,
    "x_position": null,
    "y_position": null,
    "transparency": 0.9,
    "always_on_top": true,
    "auto_show_on_poe2_start": true,
    "auto_hide_on_poe2_exit": false
  },
  
  "hotkeys": {
    "_description": "Global hotkey bindings",
    "toggle_overlay": "<ctrl>+<shift>+o",
    "quick_search": "<ctrl>+<shift>+f",
    "hide_overlay": "<escape>",
    "show_settings": "<ctrl>+<shift>+s"
  },
  
  "api": {
    "_description": "API communication settings",
    "rate_limit_requests": 10,
    "rate_limit_window": 60,
    "cache_ttl": 300,
    "request_timeout": 10,
    "user_agent": "POE2-Master-Overlay/1.0 (Linux)"
  },
  
  "search": {
    "_description": "Item search preferences",
    "default_league": "Early Access",
    "max_results": 10,
    "price_sort": "asc",
    "include_offline": false,
    "min_stock": 1
  },
  
  "process": {
    "_description": "POE2 process detection settings",
    "poe2_executable_names": [
      "PathOfExile_x64Steam.exe",
      "PathOfExile.exe",
      "PathOfExile_x64.exe",
      "PathOfExileTwo.exe"
    ],
    "check_interval": 2.0
  },
  
  "appearance": {
    "_description": "Visual appearance settings",
    "theme": "dark",
    "font_family": "Arial",
    "font_size": 10,
    "results_font_family": "Consolas",
    "results_font_size": 10
  },
  
  "debug": {
    "_description": "Debug and logging options",
    "enable_logging": true,
    "log_level": "INFO",
    "log_api_requests": false,
    "show_mock_data_warning": true
  }
}
