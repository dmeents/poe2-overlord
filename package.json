{
  "name": "poe2-master",
  "private": true,
  "version": "0.1.0",
  "description": "A powerful game overlay for Path of Exile 2 built with Tauri and React",
  "author": "POE2 Master Team",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @poe2-master/frontend dev",
    "build": "yarn workspace @poe2-master/frontend build",
    "lint": "yarn workspace @poe2-master/frontend lint",
    "preview": "yarn workspace @poe2-master/frontend preview",
    "tauri": "yarn workspace @poe2-master/frontend tauri",
    "tauri:dev": "yarn workspace @poe2-master/frontend tauri:dev",
    "tauri:build": "yarn workspace @poe2-master/frontend tauri:build",
    "tauri:info": "yarn workspace @poe2-master/frontend tauri:info",
    "clean": "yarn workspace @poe2-master/frontend clean",
    "format": "yarn workspace @poe2-master/frontend format",
    "install:all": "yarn install",
    "build:all": "yarn build && yarn tauri:build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0"
  }
}
