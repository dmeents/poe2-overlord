{
  "name": "poe2-overlord",
  "private": true,
  "version": "0.1.0",
  "description": "A powerful game overlay for Path of Exile 2 built with Tauri and React",
  "author": "POE2 Overlord Team",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "yarn@4.9.3",
  "scripts": {
    "build": "tauri build --config packages/backend/tauri.conf.json",
    "dev": "tauri dev --config packages/backend/tauri.conf.json",
    "format": "yarn format:ts && yarn format:rust",
    "format:rust": "yarn workspace @poe2-overlord/backend format",
    "format:rust:check": "yarn workspace @poe2-overlord/backend format:check",
    "format:ts": "yarn workspace @poe2-overlord/frontend format",
    "install:all": "yarn install && cd packages/backend && cargo fetch && cd ../../",
    "lint": "yarn lint:ts && yarn lint:rust",
    "lint:rust": "yarn workspace @poe2-overlord/backend lint",
    "lint:ts": "yarn workspace @poe2-overlord/frontend lint",
    "test": "yarn test:backend && yarn test:frontend",
    "test:backend": "yarn workspace @poe2-overlord/backend test",
    "test:backend:verbose": "yarn workspace @poe2-overlord/backend test:verbose",
    "test:backend:watch": "yarn workspace @poe2-overlord/backend test:watch",
    "test:frontend": "yarn workspace @poe2-overlord/frontend test",
    "check:backend": "yarn workspace @poe2-overlord/backend check",
    "build:backend": "yarn workspace @poe2-overlord/backend build",
    "clean:backend": "yarn workspace @poe2-overlord/backend clean"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.16"
  }
}
