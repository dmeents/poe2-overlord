{
  "name": "poe2-overlord",
  "private": true,
  "version": "0.0.4",
  "description": "A powerful companion app for Path of Exile 2 built with Tauri and React",
  "author": "David Meents",
  "license": "PolyForm-Shield-1.0.0",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "tauri build --config packages/backend/tauri.conf.json",
    "dev": "tauri dev --config packages/backend/tauri.conf.json",
    "dev:website": "pnpm --filter @poe2-overlord/website dev",
    "build:website": "pnpm --filter @poe2-overlord/website build",
    "start:website": "pnpm --filter @poe2-overlord/website start",
    "lint:website": "pnpm --filter @poe2-overlord/website lint",
    "typecheck:website": "pnpm --filter @poe2-overlord/website typecheck",
    "format": "pnpm --filter '@poe2-overlord/*' --parallel run format",
    "format:rust": "pnpm --filter @poe2-overlord/backend format",
    "format:rust:check": "pnpm --filter @poe2-overlord/backend format:check",
    "format:ts": "pnpm --filter @poe2-overlord/frontend format",
    "lint": "pnpm --filter '@poe2-overlord/*' --parallel run lint",
    "lint:rust": "pnpm --filter @poe2-overlord/backend lint",
    "lint:ts": "pnpm --filter @poe2-overlord/frontend lint",
    "typecheck": "pnpm --filter '@poe2-overlord/*' --parallel run typecheck",
    "test": "pnpm --filter '@poe2-overlord/*' --parallel run test",
    "test:backend": "pnpm --filter @poe2-overlord/backend test",
    "test:backend:verbose": "pnpm --filter @poe2-overlord/backend test:verbose",
    "test:backend:watch": "pnpm --filter @poe2-overlord/backend test:watch",
    "test:frontend": "pnpm --filter @poe2-overlord/frontend test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "check:backend": "pnpm --filter @poe2-overlord/backend check",
    "probe:version": "node scripts/extract-game-data/probe-version.mjs",
    "extract:gamedata": "node scripts/extract-game-data/extract.mjs",
    "extract:gamedata:local": "node scripts/extract-game-data/extract-local.mjs",
    "bump-version": "node scripts/bump-version.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@tauri-apps/cli": "^2.9.6"
  }
}
