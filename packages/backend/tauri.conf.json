{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "POE2 Overlord",
  "version": "0.1.0",
  "identifier": "com.poe2overlord.desktop",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn workspace @poe2-overlord/frontend dev",
    "beforeBuildCommand": "yarn workspace @poe2-overlord/frontend build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "POE2 Overlord",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": false,
        "focusable": true,
        "skipTaskbar": false,
        "transparent": false,
        "shadow": true,
        "center": true,
        "closable": true,
        "minimizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
