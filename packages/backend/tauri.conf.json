{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "POE2 Overlord",
  "version": "0.1.0",
  "identifier": "com.poe2overlord.overlay",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "yarn workspace @poe2-overlord/frontend dev",
    "beforeBuildCommand": "yarn workspace @poe2-overlord/frontend build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "POE2 Overlord",
        "width": 420,
        "height": 300,
        "minWidth": 300,
        "minHeight": 200,
        "maxWidth": 600,
        "maxHeight": 800,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": true,
        "center": false,
        "x": 100,
        "y": 100,
        "acceptFirstMouse": true,
        "tabbingIdentifier": "poe2-overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": false
    }
  }
}
